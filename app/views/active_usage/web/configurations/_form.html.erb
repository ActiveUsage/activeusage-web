<%= form_with(model: configuration) do |form| %>
  <% if configuration.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(configuration.errors.count, "error") %> prohibited this configuration from being saved:</h2>

      <ul>
        <% configuration.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :compute_cost_per_hour, style: "display: block" %>
    <%= form.text_field :compute_cost_per_hour %>
  </div>

  <div>
    <%= form.label :database_cost_per_hour, style: "display: block" %>
    <%= form.text_field :database_cost_per_hour %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
