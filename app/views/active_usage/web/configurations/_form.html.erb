<%= form_with(model: configuration) do |form| %>
  <div class="au-def">
    <div class="au-def-item">
      <%= form.label :compute_cost_per_hour, "Compute cost per hour", class: "au-def-label" %>
      <%= form.text_field :compute_cost_per_hour,
            class: "au-def-input#{ ' au-def-input--error' if configuration.errors[:compute_cost_per_hour].any? }",
            placeholder: "0.0000" %>
      <% configuration.errors[:compute_cost_per_hour].each do |msg| %>
        <span class="au-field-error"><%= msg %></span>
      <% end %>
    </div>
    <div class="au-def-item">
      <%= form.label :database_cost_per_hour, "Database cost per hour", class: "au-def-label" %>
      <%= form.text_field :database_cost_per_hour,
            class: "au-def-input#{ ' au-def-input--error' if configuration.errors[:database_cost_per_hour].any? }",
            placeholder: "0.0000" %>
      <% configuration.errors[:database_cost_per_hour].each do |msg| %>
        <span class="au-field-error"><%= msg %></span>
      <% end %>
    </div>
  </div>
  <div class="au-card-footer">
    <%= form.submit "Save", class: "au-btn au-btn-primary au-ml-auto" %>
  </div>
<% end %>
